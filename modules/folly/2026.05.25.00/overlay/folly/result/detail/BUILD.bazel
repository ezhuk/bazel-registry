    include_prefix = "folly/result/detail",
    deps = [
        "//folly/lang:exception",
        "//folly/result:rich_error_fwd",
    ],
)

cc_library(
    name = "ptr_immortal_exception_storage",
    hdrs = ["ptr_immortal_exception_storage.h"],
    include_prefix = "folly/result/detail",
    deps = [
        "//folly/lang:safe_assert",
        "//folly/result:rich_error_base",
    ],
)

cc_library(
    name = "result_or_unwind",
    hdrs = ["result_or_unwind.h"],
    include_prefix = "folly/result/detail",
    deps = [
