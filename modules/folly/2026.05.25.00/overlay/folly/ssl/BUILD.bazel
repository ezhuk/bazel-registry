    include_prefix = "folly/ssl",
    deps = [
        "//folly/portability:openssl",
    ],
)

cc_library(
    name = "password_collector",
    srcs = ["PasswordCollector.cpp"],
    hdrs = ["PasswordCollector.h"],
    include_prefix = "folly/ssl",
)

cc_library(
    name = "ssl_session",
    hdrs = ["SSLSession.h"],
