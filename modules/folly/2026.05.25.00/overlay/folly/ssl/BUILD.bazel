    hdrs = ["OpenSSLCertUtils.h"],
    include_prefix = "folly/ssl",
    deps = [
        ":openssl_ptr_types",
        "//folly:file_util",
        "//folly:optional",
        "//folly:scope_guard",
        "//folly:string",
        "//folly/io:iobuf",
        "//folly/portability:openssl",
    ],
)

cc_library(
    name = "openssl_hash",
    srcs = ["OpenSSLHash.cpp"],
    hdrs = ["OpenSSLHash.h"],
    include_prefix = "folly/ssl",
    deps = [
        ":openssl_ptr_types",
        "//folly:exception",
        "//folly:format",
        "//folly:range",
        "//folly/io:iobuf",
        "//folly/portability:openssl",
        "@fmt",
    ],
)

cc_library(
    name = "openssl_key_utils",
    srcs = ["OpenSSLKeyUtils.cpp"],
    hdrs = ["OpenSSLKeyUtils.h"],
    include_prefix = "folly/ssl",
    deps = [
        ":openssl_ptr_types",
        ":password_collector",
