cc_library(
    name = "unbounded_blocking_queue",
    hdrs = ["UnboundedBlockingQueue.h"],
    include_prefix = "folly/executors/task_queue",
    deps = [
        ":blocking_queue",
        "//folly/concurrency:unbounded_queue",
        "//folly/synchronization:lifo_sem",
    ],
