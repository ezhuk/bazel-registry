load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "blocking_queue",
    hdrs = ["BlockingQueue.h"],
    include_prefix = "folly/executors/task_queue",
    deps = [
        "//folly:c_portability",
        "//folly:optional",
        "@glog",
    ],
)

cc_library(
    name = "lifo_sem_mpmc_queue",
    hdrs = ["LifoSemMPMCQueue.h"],
    include_prefix = "folly/executors/task_queue",
    deps = [
        ":blocking_queue",
        "//folly:mpmc_queue",
        "//folly/synchronization:lifo_sem",
    ],
)

cc_library(
    name = "priority_lifo_sem_mpmc_queue",
    hdrs = ["PriorityLifoSemMPMCQueue.h"],
    include_prefix = "folly/executors/task_queue",
    deps = [
        ":blocking_queue",
        "//folly:executor",
        "//folly:mpmc_queue",
        "//folly:range",
        "//folly/synchronization:lifo_sem",
        "@glog",
    ],
)

cc_library(
    name = "priority_unbounded_blocking_queue",
    hdrs = ["PriorityUnboundedBlockingQueue.h"],
