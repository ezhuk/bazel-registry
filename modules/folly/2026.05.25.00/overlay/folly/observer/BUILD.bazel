    textual_hdrs = [
        "Observer-inl.h",
        "Observer-pre.h",
    ],
    deps = [
        "//folly:shared_mutex",
        "//folly:synchronized",
        "//folly:thread_local",
        "//folly/functional:invoke",
        "//folly/observer/detail:observer_manager",
    ],
)

cc_library(
    name = "read_mostly_tl_observer",
    hdrs = ["ReadMostlyTLObserver.h"],
    include_prefix = "folly/observer",
    deps = [
        ":observer",
        "//folly/concurrency/memory:read_mostly_shared_ptr",
        "//folly/observer/detail:observer_manager",
    ],
)

cc_library(
    name = "simple_observable",
    hdrs = ["SimpleObservable.h"],
    include_prefix = "folly/observer",
    textual_hdrs = ["SimpleObservable-inl.h"],
    deps = [
        ":observable",
        ":observer",
        "//folly:function",
        "//folly:synchronized",
        "//folly/synchronization:delayed_init",
    ],
)

cc_library(
    name = "with_jitter",
    hdrs = ["WithJitter.h"],
    include_prefix = "folly/observer",
    textual_hdrs = ["WithJitter-inl.h"],
    deps = [
        ":observable",
        ":observer",
        "//folly:default_keep_alive_executor",
