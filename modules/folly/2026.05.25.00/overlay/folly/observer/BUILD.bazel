load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "core_cached_observer",
    hdrs = ["CoreCachedObserver.h"],
    include_prefix = "folly/observer",
    deps = [
        ":observer",
        "//folly/concurrency:core_cached_shared_ptr",
        "//folly/observer/detail:observer_manager",
    ],
)

cc_library(
    name = "hazptr_observer",
    hdrs = ["HazptrObserver.h"],
    include_prefix = "folly/observer",
    deps = [
        ":observer",
        "//folly:synchronized",
        "//folly/observer/detail:observer_manager",
        "//folly/synchronization:hazptr",
    ],
)

cc_library(
    name = "observable",
    hdrs = ["Observable.h"],
    include_prefix = "folly/observer",
    textual_hdrs = ["Observable-inl.h"],
    deps = [
        ":observer",
        "//folly:function",
        "//folly/synchronization:baton",
    ],
)

cc_library(
    name = "observer",
    hdrs = ["Observer.h"],
