load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "barrier",
    srcs = ["Barrier.cpp"],
    hdrs = ["Barrier.h"],
    include_prefix = "folly/futures",
    deps = [
        ":core",
        "//folly:scope_guard",
        "//folly/lang:new",
        "@glog",
    ],
)

cc_library(
    name = "cleanup",
    hdrs = ["Cleanup.h"],
    include_prefix = "folly/futures",
    deps = [
        "//folly/futures:core",
        "@glog",
    ],
)

cc_library(
    name = "core",
    srcs = [
        "Future.cpp",
        "HeapTimekeeper.cpp",
        "Promise.cpp",
        "ThreadWheelTimekeeper.cpp",
    ],
    hdrs = [
        "Future.h",
        "Future-inl.h",
        "Future-pre.h",
        "HeapTimekeeper.h",
        "Promise.h",
        "Promise-inl.h",
        "Retrying.h",
        "ThreadWheelTimekeeper.h",
        "WTCallback.h",
    ],
    include_prefix = "folly/futures",
    deps = [
        ":portability",
        "//folly:chrono",
        "//folly:likely",
        "//folly:optional",
        "//folly:portability",
        "//folly:random",
        "//folly:scope_guard",
        "//folly:singleton",
        "//folly:traits",
        "//folly:try",
        "//folly:unit",
        "//folly:utility",
        "//folly/container:foreach",
        "//folly/container:intrusive_heap",
        "//folly/coro:traits",
        "//folly/detail:async_trace",
        "//folly/executors:drivable_executor",
        "//folly/executors:executor_with_priority",
        "//folly/executors:global_executor",
        "//folly/executors:inline_executor",
        "//folly/executors:queued_immediate_executor",
        "//folly/executors:timed_drivable_executor",
        "//folly/fibers:core",
        "//folly/functional:invoke",
        "//folly/futures/detail:core",
        "//folly/io/async:async_base",
        "//folly/lang:exception",
        "//folly/lang:pretty",
        "//folly/lang:safe_assert",
        "//folly/portability:gflags",
        "//folly/synchronization:distributed_mutex",
        "//folly/synchronization:relaxed_atomic",
        "//folly/synchronization:saturating_semaphore",
        "//folly/synchronization:wait_options",
        "//folly/system:thread_name",
    ],
)

cc_library(
    name = "future_splitter",
    hdrs = ["FutureSplitter.h"],
    include_prefix = "folly/futures",
    deps = [
        ":core",
        ":shared_promise",
        "//folly/lang:exception",
    ],
)

cc_library(
    name = "futures",
    deps = [
        ":barrier",
        ":core",
        ":future_splitter",
        ":shared_promise",
        "//folly/executors:inline_executor",
        "//folly/executors:manual_executor",
        "//folly/executors:queued_immediate_executor",
        "//folly/executors:scheduled_executor",
    ],
)

cc_library(
    name = "manual_timekeeper",
    srcs = ["ManualTimekeeper.cpp"],
    hdrs = ["ManualTimekeeper.h"],
    include_prefix = "folly/futures",
    deps = [
        "//folly:synchronized",
        "//folly/futures:core",
        "//folly/synchronization:atomic_util",
    ],
)

cc_library(
    name = "portability",
    hdrs = ["Portability.h"],
    include_prefix = "folly/futures",
    deps = ["//folly:portability"],
)

cc_library(
    name = "shared_promise",
    srcs = ["SharedPromise.cpp"],
    hdrs = [
        "SharedPromise.h",
        "SharedPromise-inl.h",
    ],
    include_prefix = "folly/futures",
    deps = [
        ":core",
        "//folly:portability",
        "//folly/executors:inline_executor",
        "//folly/lang:exception",
    ],
