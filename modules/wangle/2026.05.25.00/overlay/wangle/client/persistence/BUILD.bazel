    include_prefix = "wangle/client/persistence",
    deps = [
        ":persistence",
    ],
)

cc_library(
    name = "lru_in_memory_cache",
    hdrs = ["LRUInMemoryCache.h"],
    include_prefix = "wangle/client/persistence",
    textual_hdrs = ["LRUInMemoryCache-inl.h"],
    deps = [
        ":persistence",
    ],
)

cc_library(
    name = "lru_persistent_cache",
    hdrs = ["LRUPersistentCache.h"],
    include_prefix = "wangle/client/persistence",
    textual_hdrs = ["LRUPersistentCache-inl.h"],
    deps = [
        ":persistence",
    ],
)

cc_library(
    name = "persistence",
