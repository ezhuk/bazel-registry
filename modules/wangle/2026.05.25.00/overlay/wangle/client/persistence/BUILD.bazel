    deps = [
        ":persistence",
    ],
)

cc_library(
    name = "persistent_cache_common",
    srcs = ["PersistentCacheCommon.cpp"],
    hdrs = ["PersistentCacheCommon.h"],
    include_prefix = "wangle/client/persistence",
    deps = [
        ":persistence",
    ],
)
