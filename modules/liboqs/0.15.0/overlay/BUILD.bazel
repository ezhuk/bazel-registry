load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_license//rules:license.bzl", "license")

package(default_applicable_licenses = [":license"])

license(
    name = "license",
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "LICENSE.txt",
)

TEXTUAL_C_SRCS = [
    "src/kem/frodokem/external/frodo_macrify_aes_avx2.c",
    "src/kem/frodokem/external/frodo_macrify_aes_portable.c",
    "src/kem/frodokem/external/frodo_macrify_as_plus_e.c",
    "src/kem/frodokem/external/frodo_macrify_optimized.c",
    "src/kem/frodokem/external/frodo_macrify_shake_avx2.c",
    "src/kem/frodokem/external/frodo_macrify_shake_portable.c",
    "src/kem/frodokem/external/kem.c",
    "src/kem/frodokem/external/noise.c",
    "src/kem/frodokem/external/util.c",
    "src/sig_stfl/xmss/sig_stfl_xmss_xmssmt.c",
]

PUBLIC_HEADERS = {
    "src/oqs.h": "include/oqs/oqs.h",
    "src/common/aes/aes_ops.h": "include/oqs/aes_ops.h",
    "src/common/common.h": "include/oqs/common.h",
    "src/common/rand/rand.h": "include/oqs/rand.h",
    "src/common/sha2/sha2_ops.h": "include/oqs/sha2_ops.h",
    "src/common/sha3/sha3_ops.h": "include/oqs/sha3_ops.h",
    "src/common/sha3/sha3x4_ops.h": "include/oqs/sha3x4_ops.h",
    "src/kem/bike/kem_bike.h": "include/oqs/kem_bike.h",
    "src/kem/classic_mceliece/kem_classic_mceliece.h": "include/oqs/kem_classic_mceliece.h",
    "src/kem/frodokem/kem_frodokem.h": "include/oqs/kem_frodokem.h",
    "src/kem/hqc/kem_hqc.h": "include/oqs/kem_hqc.h",
    "src/kem/kem.h": "include/oqs/kem.h",
    "src/kem/kyber/kem_kyber.h": "include/oqs/kem_kyber.h",
    "src/kem/ml_kem/kem_ml_kem.h": "include/oqs/kem_ml_kem.h",
    "src/kem/ntru/kem_ntru.h": "include/oqs/kem_ntru.h",
    "src/kem/ntruprime/kem_ntruprime.h": "include/oqs/kem_ntruprime.h",
    "src/sig/cross/sig_cross.h": "include/oqs/sig_cross.h",
    "src/sig/falcon/sig_falcon.h": "include/oqs/sig_falcon.h",
    "src/sig/mayo/sig_mayo.h": "include/oqs/sig_mayo.h",
    "src/sig/ml_dsa/sig_ml_dsa.h": "include/oqs/sig_ml_dsa.h",
    "src/sig/sig.h": "include/oqs/sig.h",
    "src/sig/slh_dsa/sig_slh_dsa.h": "include/oqs/sig_slh_dsa.h",
    "src/sig/snova/sig_snova.h": "include/oqs/sig_snova.h",
