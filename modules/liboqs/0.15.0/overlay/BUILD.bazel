    "src/sig_stfl/xmss/sig_stfl_xmss.h": "include/oqs/sig_stfl_xmss.h",
}

PRIVATE_HEADERS = {
    "src/common/aes/aes.h": "include/oqs/aes.h",
    "src/common/sha2/sha2.h": "include/oqs/sha2.h",
    "src/common/sha3/sha3.h": "include/oqs/sha3.h",
    "src/common/sha3/sha3x4.h": "include/oqs/sha3x4.h",
}

HEADER_MAPPINGS = dict(PUBLIC_HEADERS)

HEADER_MAPPINGS.update(PRIVATE_HEADERS)

genrule(
    name = "public_headers",
    srcs = HEADER_MAPPINGS.keys(),
    outs = list(HEADER_MAPPINGS.values()) + ["include/oqs/oqsconfig.h"],
    cmd = "\n".join([
        "set -eu",
        "mkdir -p $(@D)/include/oqs",
    ] + [
        "cp $(location %s) $(@D)/%s" % (src, dst)
        for src, dst in HEADER_MAPPINGS.items()
    ] + [
        "cat > $(@D)/include/oqs/oqsconfig.h <<'EOF'",
        "// Generated by the Bazel overlay.",
        "#ifndef OQS_OQSCONFIG_H",
        "#define OQS_OQSCONFIG_H",
        "#define OQS_VERSION_TEXT \"0.15.0\"",
        "#define OQS_VERSION_MAJOR 0",
        "#define OQS_VERSION_MINOR 15",
        "#define OQS_VERSION_PATCH 0",
        "#define OQS_USE_PTHREADS 1",
        "#define OQS_USE_CUPQC 0",
        "#define OQS_USE_ICICLE 0",
        "#endif",
        "EOF",
    ]),
)

cc_library(
    name = "oqs",
    srcs = [
        "src/common/aes/aes.c",
        "src/common/aes/aes_c.c",
        "src/common/aes/aes_impl.c",
        "src/common/common.c",
        "src/common/pqclean_shims/fips202.c",
        "src/common/pqclean_shims/fips202x4.c",
        "src/common/rand/rand.c",
        "src/common/sha2/sha2.c",
        "src/common/sha2/sha2_c.c",
        "src/common/sha2/sha2_impl.c",
        "src/common/sha3/sha3.c",
        "src/common/sha3/sha3x4.c",
        "src/common/sha3/xkcp_low/KeccakP-1600/plain-64bits/KeccakP-1600-opt64.c",
        "src/common/sha3/xkcp_low/KeccakP-1600times4/serial/KeccakP-1600-times4-on1.c",
        "src/common/sha3/xkcp_sha3.c",
        "src/common/sha3/xkcp_sha3x4.c",
        "src/kem/kem.c",
        "src/sig/sig.c",
        "src/sig_stfl/sig_stfl.c",
    ],
    hdrs = [":public_headers"],
    include_prefix = "",
    includes = [
        "include",
        "src",
        "src/common/sha3/xkcp_low/KeccakP-1600/plain-64bits",
    ],
    strip_include_prefix = "include",
    textual_hdrs = TEXTUAL_C_SRCS + glob([
        "src/**/*.h",
        "src/common/sha3/xkcp_low/**/*.inc",
        "src/common/sha3/xkcp_low/**/*.macros",
    ]),
    visibility = ["//visibility:public"],
)
