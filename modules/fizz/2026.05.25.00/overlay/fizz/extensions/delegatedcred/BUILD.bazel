        "@folly//folly/ssl:openssl_cert_utils",
        "@folly//folly/ssl:openssl_ptr_types",
    ],
)

cc_library(
    name = "peer_delegated_credential",
    hdrs = ["PeerDelegatedCredential.h"],
    include_prefix = "fizz/extensions/delegatedcred",
    textual_hdrs = ["PeerDelegatedCredential-inl.h"],
