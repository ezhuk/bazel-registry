cc_library(
    name = "self_delegated_credential",
    hdrs = ["SelfDelegatedCredential.h"],
    include_prefix = "fizz/extensions/delegatedcred",
    textual_hdrs = ["SelfDelegatedCredential-inl.h"],
    deps = [
        ":delegated_credential",
        ":delegated_credential_utils",
        "//fizz/backend:openssl",
        "@folly//folly/ssl:openssl_cert_utils",
    ],
)

cc_library(
    name = "serialization",
    srcs = ["Serialization.cpp"],
    hdrs = ["Serialization.h"],
    include_prefix = "fizz/extensions/delegatedcred",
    deps = [
        ":delegated_credential",
        ":delegated_credential_utils",
        ":self_delegated_credential",
        "@fmt",
        "@folly//folly:base64",
        "@folly//folly:range",
    ],
