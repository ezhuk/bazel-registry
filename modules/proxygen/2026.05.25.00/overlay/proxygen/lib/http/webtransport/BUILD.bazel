    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        ":webtransport_capsule_codec",
        ":wt_stream_manager",
        "//proxygen/lib/http/codec:codec_common",
        "//proxygen/lib/http/codec:direction",
        "@folly//folly/logging",
        "@mvfst//quic/codec:types",
    ],
)
