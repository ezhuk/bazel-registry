        "@mvfst//quic/common/address:quic_socket_address_bridge",
        "@mvfst//quic/priority:http_priority_queue",
    ],
)

cc_library(
    name = "webtransport",
    srcs = ["WebTransport.cpp"],
    hdrs = ["WebTransport.h"],
    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        "@folly//folly:cancellation_token",
        "@folly//folly:expected",
        "@folly//folly:network_address",
        "@folly//folly:optional",
        "@folly//folly/futures:core",
        "@folly//folly/io:iobuf",
        "@mvfst//quic/api:quic_callbacks",
        "@mvfst//quic/api:transport_info",
        "@mvfst//quic/priority:priority_queue",
    ],
)

cc_library(
    name = "webtransportimpl",
    srcs = ["WebTransportImpl.cpp"],
    hdrs = ["WebTransportImpl.h"],
    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        ":flow_controller",
        ":webtransport",
        "//proxygen/lib/http/codec:codec_common",
        "@glog",
        "@mvfst//quic:constants",
    ],
)

cc_library(
    name = "webtransport_session",
    srcs = ["WebTransportSession.cpp"],
    hdrs = ["WebTransportSession.h"],
    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        ":wt_stream_manager",
        ":wt_util",
        "//proxygen/lib/http/session:http_transaction",
        "@mvfst//quic/priority:priority_queue",
