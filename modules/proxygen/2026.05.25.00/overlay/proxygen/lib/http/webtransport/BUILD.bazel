load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "flow_controller",
    hdrs = ["FlowController.h"],
    include_prefix = "proxygen/lib/http/webtransport",
)

cc_library(
    name = "httpwebtransport",
