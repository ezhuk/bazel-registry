    hdrs = ["HTTPWebTransport.h"],
    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        "//proxygen/lib/http:message",
        "//proxygen/lib/http/structuredheaders:decoder",
        "//proxygen/lib/http/structuredheaders:encoder",
        "@folly//folly:expected",
        "@folly//folly:optional",
    ],
)

cc_library(
    name = "quicwebtransport",
    srcs = ["QuicWebTransport.cpp"],
    hdrs = ["QuicWebTransport.h"],
    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        ":webtransportimpl",
        "@folly//folly/logging",
        "@mvfst//quic/api:transport",
        "@mvfst//quic/common/address:quic_socket_address_bridge",
    ],
)

cc_library(
    name = "quic_wt_session",
    srcs = ["QuicWtSession.cpp"],
    hdrs = ["QuicWtSession.h"],
    include_prefix = "proxygen/lib/http/webtransport",
    deps = [
        ":webtransport",
        ":wt_stream_manager",
        ":wt_util",
