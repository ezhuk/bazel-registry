        "QLoggerTypes.cpp",
    ],
    hdrs = [
        "BaseQLogger.h",
        "QLoggerTypes.h",
    ],
    include_prefix = "quic/logging",
    deps = [
        ":qlogger",
        ":qlogger_constants",
        "//folly:dynamic",
        "//quic:exception",
        "//quic/codec:types",
        "//quic/common:string_utils",
        "//quic/priority:priority_queue",
    ],
)

cc_library(
    name = "file_qlogger",
    srcs = ["FileQLogger.cpp"],
    hdrs = ["FileQLogger.h"],
    include_prefix = "quic/logging",
    deps = [
        ":base_qlogger",
        ":qlog_schema",
        ":qlogger_constants",
        "//folly:dynamic",
        "//folly/compression",
        "//folly/logging",
        "//quic/codec:types",
        "//quic/common:mvfst_logging",
    ],
)

cc_library(
